# Gere valores exclusivos antes de usar em produção. Nunca envie seu .env ao Git.
SECRET_KEY=gere_um_segredo_aleatorio_com_pelo_menos_48_caracteres
APP_BASE_URL=https://finora.exemplo.com
APP_TIMEZONE=America/Sao_Paulo
FINORA_PORT=5000

# Docker Compose / MySQL
MYSQL_DATABASE=finora
MYSQL_USER=finora
MYSQL_PASSWORD=troque_esta_senha
MYSQL_ROOT_PASSWORD=troque_esta_senha_root
# Codifique caracteres especiais da senha para URL antes de montar DATABASE_URL.
DATABASE_URL=mysql+mysqldb://finora:senha_codificada_para_url@db:3306/finora?charset=utf8mb4

LOG_TO_FILE=1
LOG_DIRECTORY=logs
BACKUP_STORAGE_DIR=backups
ENABLE_BACKUP_SCHEDULER=1
ENABLE_DEFAULT_USER_SEED=0
TRUST_PROXY_HEADERS=0

# SMTP opcional para recuperação por e-mail no servidor
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_USE_TLS=1
MAIL_USE_SSL=0
MAIL_DEFAULT_SENDER=
MAIL_FROM_NAME=Finora
MAIL_TIMEOUT_SECONDS=10

UPDATE_CHANNEL=stable
UPDATE_MANIFEST_URL=
UPDATE_DOWNLOAD_DIR=updates
UPDATE_TARGET_ROOT=.
UPDATE_CHECK_TIMEOUT_SECONDS=20
UPDATE_DOWNLOAD_TIMEOUT_SECONDS=60
UPDATE_NETWORK_RETRY_ATTEMPTS=3
UPDATE_NETWORK_RETRY_BACKOFF_SECONDS=2
UPDATE_ALLOW_LOCAL_ASSETS=0
ACTIVITY_LOG_RETENTION_DAYS=180
SYSTEM_EVENT_RETENTION_DAYS=90
